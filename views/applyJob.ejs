<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <%- include('partials/styles.ejs') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Apply for Job</title>
</head>
<body class="bg-light">
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card worklah-card form-card">
                    <div class="card-header worklah-card-header">
                        <h3 class="mb-0">Job Application</h3>
                    </div>

                    <div class="card-body">
                        <% if (errors && errors.length > 0) { %>
                            <div class="alert alert-danger">
                                <% errors.forEach(function(error) { %>
                                    <p class="mb-0"><%= error %></p>
                                <% }); %>
                            </div>
                        <% } %>

                        <p>
                            <strong>Applying For:</strong>
                            <%= job.company %> - <%= job.title %>
                        </p>

                        <p>
                            <strong>Student:</strong>
                            <%= user.username %>
                        </p>

                        <p>
                            <strong>Email:</strong>
                            <%= user.email %>
                        </p>

                        <div class="alert alert-info">
                            Your saved profile resume will be attached to
                            this application.

                            <a
                                href="/profile/resume"
                                class="alert-link">
                                View Resume
                            </a>
                        </div>

                        <form
                            action="/job/<%= job.id %>/apply"
                            method="POST">
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-worklah">
                                    Submit Application
                                </button>
                                <a href="/joblist" class="btn btn-secondary">
                                    Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
