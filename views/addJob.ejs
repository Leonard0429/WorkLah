<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <%- include('partials/styles.ejs') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Add Job</title>
</head>
<body class="bg-light">
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card worklah-card form-card">
                    <div class="card-header worklah-card-header">
                        <h3 class="mb-0">Add New Job</h3>
                    </div>

                    <div class="card-body">
                        <% if (errors && errors.length > 0) { %>
                            <div class="alert alert-danger">
                                <% errors.forEach(function(error) { %>
                                    <p class="mb-0"><%= error %></p>
                                <% }); %>
                            </div>
                        <% } %>

                        <form action="/addjob" method="POST">
                            <div class="mb-3">
                                <label for="company" class="form-label">Company</label>
                                <input type="text" id="company" name="company" class="form-control" required>
                            </div>

                            <div class="mb-3">
                                <label for="title" class="form-label">Job Title</label>
                                <input type="text" id="title" name="title" class="form-control" required>
                            </div>

                            <div class="mb-3">
                                <label for="description" class="form-label">Description</label>
                                <textarea id="description" name="description" class="form-control" required></textarea>
                            </div>

                            <%
                                const jobCategories = [
                                    'Administration',
                                    'Customer Service',
                                    'Education',
                                    'Engineering',
                                    'Finance',
                                    'Food & Beverage',
                                    'Healthcare',
                                    'Hospitality',
                                    'Information Technology',
                                    'Logistics',
                                    'Manufacturing',
                                    'Marketing',
                                    'Retail',
                                    'Sales'
                                ];
                            %>

                            <div class="mb-3">
                                <label for="category" class="form-label">
                                    Category
                                </label>

                                <select
                                    id="category"
                                    name="category"
                                    class="form-select"
                                    onchange="toggleOtherCategory()"
                                    required>

                                    <option value="">
                                        Select an industry
                                    </option>

                                    <% for (let i = 0; i < jobCategories.length; i++) { %>
                                        <option value="<%= jobCategories[i] %>">
                                            <%= jobCategories[i] %>
                                        </option>
                                    <% } %>

                                    <option value="Others">
                                        Others
                                    </option>
                                </select>

                                <div id="otherCategoryContainer" class="mt-3 d-none">
                                    <label for="otherCategory" class="form-label">
                                        Other Category
                                    </label>

                                    <input
                                        type="text"
                                        id="otherCategory"
                                        name="otherCategory"
                                        class="form-control"
                                        maxlength="50"
                                        placeholder="Enter the industry">
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="pay" class="form-label">Pay</label>
                                <input type="number" id="pay" name="pay" class="form-control" min="0" step="0.01" required>
                            </div>

                            <div class="mb-3">
                                <label for="location" class="form-label">Location</label>
                                <input type="text" id="location" name="location" class="form-control">
                            </div>

                            <div class="mb-4">
                                <label for="deadline" class="form-label">Application Deadline</label>
                                <input type="date" id="deadline" name="deadline" class="form-control" required>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-worklah">
                                    Add Job
                                </button>
                                <a href="/joblist" class="btn btn-secondary">
                                    Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Display the custom category input when Others is selected
        function toggleOtherCategory() {
            const category = document.getElementById('category');
            const container = document.getElementById(
                'otherCategoryContainer'
            );
            const otherCategory = document.getElementById(
                'otherCategory'
            );

            if (category.value === 'Others') {
                container.classList.remove('d-none');
                otherCategory.required = true;
            } else {
                container.classList.add('d-none');
                otherCategory.required = false;
                otherCategory.value = '';
            }
        }
    </script>
</body>
</html>
