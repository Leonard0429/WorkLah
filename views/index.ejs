<!DOCTYPE html>
<html>
<head>
    <title>WorkLah</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-5">
        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <div class="text-center">
            <h1>Welcome to WorkLah</h1>
            <p class="lead">Find internships, part-time jobs, and entry-level positions in Singapore.</p>

            <% if (user) { %>
                <p>Hello, <strong><%= user.username %></strong>! You're logged in as <strong><%= user.role %></strong>.</p>
                <a href="/joblist" class="btn btn-primary btn-lg mt-3">Browse Jobs</a>
            <% } else { %>
                <a href="/register" class="btn btn-primary btn-lg mt-3">Get Started</a>
            <% } %>
        </div>
    </div>
</body>
</html>
