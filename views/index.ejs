<!DOCTYPE html>
<html>
<head>
    <title>WorkLah</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <%- include('partials/styles.ejs') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-4">
        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <div class="hero-worklah">
            <h1>Find your next opportunity, lah!</h1>
            <p class="lead">Find internships, part-time jobs, and entry-level positions in Singapore.</p>

            <% if (user) { %>
                <p>Hello, <strong><%= user.username %></strong>! You're logged in as <strong><%= user.role %></strong>.</p>
                <a href="/joblist" class="btn btn-worklah btn-lg mt-3">Browse Jobs</a>
            <% } else { %>
                <a href="/register" class="btn btn-worklah btn-lg mt-3">Get Started</a>
            <% } %>
        </div>
    </div>

    <div class="footer-worklah">
        WorkLah &middot; Built for students, by students
    </div>
</body>
</html>
