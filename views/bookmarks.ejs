<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <%- include('partials/styles.ejs') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js">
    </script>

    <title>Saved Jobs</title>
</head>

<body>
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-3">
        <h2 class="page-title">
            Saved Jobs
        </h2>

        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <% errors.forEach(function(error) { %>
                    <p class="mb-0">
                        <%= error %>
                    </p>
                <% }); %>
            </div>
        <% } %>

        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <p class="mb-0">
                        <%= message %>
                    </p>
                <% }); %>
            </div>
        <% } %>

        <% if (savedJobs.length === 0) { %>
            <div class="alert alert-info">
                You have not saved any jobs.
            </div>

            <a href="/joblist" class="btn btn-worklah">Browse Jobs</a>
        <% } else { %>
            <div class="row g-3">
                <% for (
                    let i = 0;
                    i < savedJobs.length;
                    i++
                ) { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card card-gig h-100">
                            <div class="card-body d-flex flex-column">

                                <div class="d-flex justify-content-between align-items-start mb-2">

                                    <span class="badge badge-category">
                                        <%= savedJobs[i].category %>
                                    </span>

                                    <% if (savedJobs[i].unavailable) { %>
                                        <span class="badge bg-secondary">Unavailable</span>
                                    <% } %>
                                </div>

                                <h4 class="page-title">
                                    <%= savedJobs[i].title %>
                                </h4>

                                <p class="fw-semibold">
                                    <%= savedJobs[i].company %>
                                </p>

                                <p class="mb-1">
                                    <strong>Pay:</strong>
                                    $<%= savedJobs[i].pay %>
                                </p>

                                <p class="mb-1">
                                    <strong>Location:</strong>

                                    <%= savedJobs[i].location
                                        || 'Not specified' %>
                                </p>

                                <p class="mb-3">
                                    <strong>Deadline:</strong>

                                    <% if (savedJobs[i].deadline) { %>
                                        <%= new Date(
                                            savedJobs[i].deadline
                                        ).toLocaleDateString(
                                            'en-SG',
                                            {
                                                day: '2-digit',
                                                month: 'short',
                                                year: 'numeric'
                                            }
                                        ) %>
                                    <% } else { %>
                                        No deadline
                                    <% } %>
                                </p>

                                <div class="d-flex flex-wrap gap-2 mt-auto">

                                    <a href="/job/<%= savedJobs[i].id %>" class="btn btn-primary btn-sm">
                                        View
                                    </a>

                                    <% if (!savedJobs[i].unavailable) { %>
                                        <a href="/job/<%= savedJobs[i].id %>/apply" class="btn btn-worklah btn-sm">
                                            Apply
                                        </a>
                                    <% } %>

                                    <form action="/bookmark/<%= savedJobs[i].id %>/delete" method="POST" class="m-0">

                                        <input type="hidden" name="returnPage" value="bookmarks">

                                        <button type="submit" class="btn btn-outline-danger btn-sm">Remove</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>
    </div>
</body>
</html>
