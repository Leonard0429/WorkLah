<!DOCTYPE html>
<html>
<head>
    <title>Admin - WorkLah</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <%- include('partials/styles.ejs') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-4">
        <h1 class="page-title">Welcome, <%= user.username %>!</h1>

        <div class="card worklah-card mb-4">
            <div class="card-body">
                <h4 class="page-title">Admin Account</h4>
                <p>Username: <strong><%= user.username %></strong></p>
                <p>Email: <%= user.email %></p>
                <p class="mb-0">Role: <strong><%= user.role %></strong></p>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="card worklah-card h-100">
                    <div class="card-body d-flex flex-column">
                        <h4 class="page-title">Manage Jobs</h4>
                        <p>Add, edit, review, or remove job listings.</p>
                        <a href="/joblist" class="btn btn-worklah mt-auto">
                            Open Jobs
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card worklah-card h-100">
                    <div class="card-body d-flex flex-column">
                        <h4 class="page-title">Manage Applications</h4>
                        <p>Review applicants, resumes, and application statuses.</p>
                        <a href="/applicationList" class="btn btn-worklah mt-auto">
                            Open Applications
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
