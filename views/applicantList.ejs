<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Worklah App</title>
</head>
<body>
    <%- include ('partials/navbar.ejs') %>
    <div class="container mt-3">
        <h2>Worklah</h2>          
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Applicant ID</th>
                    <th>Applicant Name</th>
                    <th>Job Applied</th>
                    <th>Edit</th>
                    <th>Delete</th>
                </tr>
            </thead>
            <tbody>
                <!-- Display the applicant information by looping through the applicant array-->
                <% for (let i = 0; i < applicant.length; i++) { %>
                    <tr>
                        <td><%= applicant[i].id %></td>
                        <td><%= applicant[i].name %></td>
                        <td><%= applicant[i].job_applied %></td>
                        <td><a href="/applicant/<%= applicant[i].id %>/update">Edit</a></td>
                        <td><a href="/applicant/<%= applicant[i].id %>/delete">Delete</a></td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</body>
</html>