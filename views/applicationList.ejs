<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Applications</title>
</head>
<body>
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-3">
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <% errors.forEach(function(error) { %>
                    <p class="mb-0"><%= error %></p>
                <% }); %>
            </div>
        <% } %>

        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <h2>
            <%= user.role === 'admin'
                ? 'Student Applications'
                : 'My Applications' %>
        </h2>

        <% if (applications.length === 0) { %>
            <div class="alert alert-info">
                No applications found.
            </div>
        <% } else { %>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <% if (user.role === 'admin') { %>
                            <th>Student</th>
                            <th>Email</th>
                            <th>Contact</th>
                        <% } %>

                        <th>Company</th>
                        <th>Job</th>
                        <th>Applied On</th>

                        <% if (user.role === 'admin') { %>
                            <th>Resume</th>
                        <% } %>

                        <th>Status</th>
                        <th>View</th>

                        <% if (user.role === 'student') { %>
                            <th>Delete</th>
                        <% } %>
                    </tr>
                </thead>

                <tbody>
                    <% for (let i = 0; i < applications.length; i++) { %>
                        <tr>
                            <% if (user.role === 'admin') { %>
                                <td><%= applications[i].username %></td>
                                <td><%= applications[i].email %></td>
                                <td><%= applications[i].contact %></td>
                            <% } %>

                            <td><%= applications[i].company %></td>
                            <td><%= applications[i].title %></td>
                            <td><%= applications[i].applied_at %></td>

                            <% if (user.role === 'admin') { %>
                                <td>
                                    <a href="/application/<%= applications[i].id %>/resume">
                                        Download
                                    </a>
                                </td>
                            <% } %>

                            <td>
                                <% if (user.role === 'admin') { %>
                                    <form
                                        action="/application/<%= applications[i].id %>/status"
                                        method="POST">
                                        <select
                                            name="status"
                                            class="form-select"
                                            onchange="this.form.submit()">
                                            <option
                                                value="pending"
                                                <%= applications[i].status === 'pending' ? 'selected' : '' %>>
                                                Pending
                                            </option>
                                            <option
                                                value="accepted"
                                                <%= applications[i].status === 'accepted' ? 'selected' : '' %>>
                                                Accepted
                                            </option>
                                            <option
                                                value="rejected"
                                                <%= applications[i].status === 'rejected' ? 'selected' : '' %>>
                                                Rejected
                                            </option>
                                        </select>
                                    </form>
                                <% } else { %>
                                    <%= applications[i].status %>
                                <% } %>
                            </td>

                            <td>
                                <a href="/application/<%= applications[i].id %>">
                                    View
                                </a>
                            </td>

                            <% if (user.role === 'student') { %>
                                <td>
                                    <% if (applications[i].status === 'pending') { %>
                                        <form
                                            action="/application/<%= applications[i].id %>/delete"
                                            method="POST"
                                            onsubmit="return confirm('Delete this pending application?')">
                                            <button
                                                type="submit"
                                                class="btn btn-danger btn-sm">
                                                Delete
                                            </button>
                                        </form>
                                    <% } else { %>
                                        Not available
                                    <% } %>
                                </td>
                            <% } %>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        <% } %>
    </div>
</body>
</html>
