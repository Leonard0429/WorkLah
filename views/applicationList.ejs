<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <%- include('partials/styles.ejs') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Applications</title>
</head>
<body>
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-3">
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <% errors.forEach(function(error) { %>
                    <p class="mb-0"><%= error %></p>
                <% }); %>
            </div>
        <% } %>

        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <h2 class="page-title">
            <%= user.role === 'admin'
                ? 'Student Applications'
                : 'My Applications' %>
        </h2>

        <% if (applications.length === 0) { %>
            <div class="alert alert-info">
                No applications found.
            </div>

        <% } else if (user.role === 'admin') { %>
            <!-- Display every student application in a card -->
            <div class="row g-3">
                <% for (let i = 0; i < applications.length; i++) { %>
                    <div class="col-md-6">
                        <div class="card worklah-card h-100">
                            <div class="card-body d-flex gap-3">
                                <div class="flex-shrink-0">
                                    <% if (
                                        applications[i]
                                            .profilePictureAvailable
                                    ) { %>
                                        <img src="/profile-picture/<%= applications[i].student_id %>"
                                            alt="<%= applications[i].username %> profile picture"
                                            class="profile-picture profile-picture-small">
                                    <% } else { %>
                                        <div class="profile-picture-placeholder profile-picture-small">
                                            <%= applications[i].username
                                                .charAt(0)
                                                .toUpperCase() %>
                                        </div>
                                    <% } %>

                                </div>

                                <div class="flex-grow-1 overflow-hidden">
                                        <h4 class="page-title mb-1">
                                            <%= applications[i].username %>
                                        </h4>

                                        <p class="mb-1 text-break">
                                            <strong>Email:</strong>
                                            <%= applications[i].email %>
                                        </p>

                                        <p class="mb-0">
                                            <strong>Contact:</strong>
                                            <%= applications[i].contact %>
                                        </p>

                                <hr>

                                <p class="mb-1">
                                    <strong>Company:</strong>
                                    <%= applications[i].company %>
                                </p>

                                <p class="mb-1">
                                    <strong>Job:</strong>
                                    <%= applications[i].title %>
                                </p>

                                <p class="mb-1">
                                    <strong>Attempt:</strong>
                                    <%= applications[i].attemptNumber %>

                                    <% if (
                                        applications[i]
                                            .isLatestAttempt
                                    ) { %>
                                        <span class="badge bg-primary">Latest</span>
                                    <% } %>
                                </p>

                                <p class="mb-3">
                                    <strong>Applied On:</strong>

                                    <% if (applications[i].applied_at) { %>
                                        <%= new Date(
                                            applications[i].applied_at
                                        ).toLocaleDateString(
                                            'en-SG',
                                            {
                                                day: '2-digit',
                                                month: 'short',
                                                year: 'numeric'
                                            }
                                        ) %>
                                    <% } else { %>
                                        Not available
                                    <% } %>
                                </p>

                                <p>
                                    <strong>Current Status:</strong>

                                    <span class="badge status-<%= applications[i].status %> text-capitalize">
                                        <%= applications[i].status %>
                                    </span>
                                </p>

                                <a href="/application/<%= applications[i].id %>/resume" class="btn btn-primary btn-sm">
                                    Download Resume
                                </a>

                                <!-- Admin can update only the latest pending attempt -->
                                <% if (
                                    applications[i].isLatestAttempt
                                    && applications[i].status
                                        === 'pending'
                                ) { %>
                                    <form action="/application/<%= applications[i].id %>/status" method="POST"
                                        class="mt-3">

                                        <label for="status-<%= applications[i].id %>" class="form-label">
                                            Update Status
                                        </label>

                                        <select id="status-<%= applications[i].id %>" name="status"
                                            class="form-select mb-2">

                                            <option value="pending" selected>Pending</option>

                                            <option value="accepted">Accepted</option>

                                            <option value="rejected">Rejected</option>
                                        </select>

                                        <button type="submit" class="btn btn-worklah">Save Status</button>
                                    </form>
                                <% } else { %>
                                    <p class="text-muted mt-3 mb-0">
                                        Status history is read-only.
                                    </p>
                                <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>

        <% } else { %>
            <!-- Students continue seeing only their own applications -->
            <div class="row g-3">
                <% for (let i = 0; i < applications.length; i++) { %>
                    <div class="col-md-6">
                        <div class="card worklah-card h-100">
                            <div class="card-body d-flex gap-3">
                                <div class="flex-shrink-0">
                                    <% if (
                                        applications[i]
                                            .profilePictureAvailable
                                    ) { %>
                                        <img src="/profile-picture/<%= applications[i].student_id %>"
                                            alt="<%= applications[i].username %> profile picture"
                                            class="profile-picture profile-picture-small">
                                    <% } else { %>
                                        <div class="profile-picture-placeholder profile-picture-small">
                                            <%= applications[i].username
                                                .charAt(0)
                                                .toUpperCase() %>
                                        </div>
                                    <% } %>
                                </div>

                                <div class="flex-grow-1 d-flex flex-column overflow-hidden">
                                    <span class="badge status-<%= applications[i].status %> text-capitalize align-self-start mb-2">
                                        <%= applications[i].status %>
                                    </span>

                                    <h4 class="page-title">
                                        <%= applications[i].title %>
                                    </h4>

                                    <p class="fw-semibold">
                                        <%= applications[i].company %>
                                    </p>

                                    <p>
                                        <strong>Applied On:</strong>

                                        <% if (applications[i].applied_at) { %>
                                            <%= new Date(
                                                applications[i].applied_at
                                            ).toLocaleDateString(
                                                'en-SG',
                                                {
                                                    day: '2-digit',
                                                    month: 'short',
                                                    year: 'numeric'
                                                }
                                            ) %>
                                        <% } else { %>
                                            Not available
                                        <% } %>
                                    </p>

                                    <p>
                                        <strong>Attempt:</strong>
                                        <%= applications[i].attemptNumber %>

                                        <% if (
                                            applications[i]
                                                .isLatestAttempt
                                        ) { %>
                                            <span class="badge bg-primary">Latest</span>
                                        <% } %>
                                    </p>

                                    <div class="d-flex flex-wrap gap-2 mt-auto">
                                        <a href="/application/<%= applications[i].id %>" class="btn btn-primary btn-sm">
                                            View
                                        </a>

                                        <% if (applications[i].status === 'pending') { %>
                                            <form action="/application/<%= applications[i].id %>/delete" method="POST"
                                                class="m-0"
                                                onsubmit="return confirm('Delete this pending application?')">

                                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                            </form>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>
    </div>
</body>
</html>
