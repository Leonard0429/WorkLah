<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <%- include('partials/styles.ejs') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Application Information</title>
</head>
<body>
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-4">
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <% errors.forEach(function(error) { %>
                    <p class="mb-0"><%= error %></p>
                <% }); %>
            </div>
        <% } %>

        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <div class="card worklah-card form-card">
            <div class="card-body">
                <h2 class="page-title">Application Details</h2>

                <p><strong>Student:</strong> <%= application.username %></p>
                <p><strong>Email:</strong> <%= application.email %></p>
                <p><strong>Contact:</strong> <%= application.contact %></p>
                <p><strong>Company:</strong> <%= application.company %></p>
                <p><strong>Job:</strong> <%= application.title %></p>
                <p>
                    <strong>Attempt:</strong>
                    <%= application.attemptNumber %>

                    <% if (application.isLatestAttempt) { %>
                        <span class="badge bg-primary">Latest</span>
                    <% } %>
                </p>
                <p>
                    <strong>Applied On:</strong>

                    <% if (application.applied_at) { %>
                        <%= new Date(application.applied_at).toLocaleDateString(
                            'en-SG',
                            {
                                day: '2-digit',
                                month: 'short',
                                year: 'numeric'
                            }
                        ) %>
                    <% } else { %>
                        Not available
                    <% } %>
                </p>
                <p>
                    <strong>Status:</strong>
                    <span class="badge status-<%= application.status %> text-capitalize">
                        <%= application.status %>
                    </span>
                </p>

                <% if (
                    user.role === 'admin'
                    && application.isLatestAttempt
                    && application.status === 'pending'
                ) { %>
                    <form action="/application/<%= application.id %>/status" method="POST" class="mt-3">
                        <label for="status" class="form-label">Update Status</label>
                        <select id="status" name="status" class="form-select mb-2">
                            <option value="pending" <%= application.status === 'pending' ? 'selected' : '' %>>
                                Pending
                            </option>
                            <option value="accepted" <%= application.status === 'accepted' ? 'selected' : '' %>>
                                Accepted
                            </option>
                            <option value="rejected" <%= application.status === 'rejected' ? 'selected' : '' %>>
                                Rejected
                            </option>
                        </select>
                        <button type="submit" class="btn btn-worklah">Save Status</button>
                    </form>
                <% } else if (user.role === 'admin') { %>
                    <p class="text-muted">
                        Status history is read-only.
                    </p>
                <% } %>

                <div class="d-flex flex-wrap align-items-center gap-2 mt-3">
                    <a href="/application/<%= application.id %>/resume" class="btn btn-primary">
                        Download Resume
                    </a>

                    <% if (
                        user.role === 'student' &&
                        application.status === 'pending'
                    ) { %>
                        <form action="/application/<%= application.id %>/delete" method="POST" class="m-0"
                            onsubmit="return confirm('Delete this pending application?')">
                            <button type="submit" class="btn btn-danger">Delete Application</button>
                        </form>
                    <% } %>

                    <a href="/applicationList" class="btn btn-secondary">Back to Applications</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
