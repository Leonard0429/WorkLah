<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <%- include('partials/styles.ejs') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Job Information</title>
</head>
<body>
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-4">
        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <% errors.forEach(function(error) { %>
                    <p class="mb-0"><%= error %></p>
                <% }); %>
            </div>
        <% } %>

        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(function(message) { %>
                    <p class="mb-0"><%= message %></p>
                <% }); %>
            </div>
        <% } %>

        <div class="card worklah-card form-card">
            <div class="card-body">
                <span class="badge badge-category mb-2">
                    <%= job.category %>
                </span>

                <h2 class="page-title"><%= job.title %></h2>

                <p>
                    <strong>Company:</strong>
                    <%= job.company %>
                </p>

                <p>
                    <strong>Description:</strong>
                    <%= job.description %>
                </p>

                <p>
                    <strong>Pay:</strong>
                    $<%= job.pay %>
                </p>

                <p>
                    <strong>Location:</strong>
                    <%= job.location || 'Not specified' %>
                </p>

                <p>
                    <strong>Deadline:</strong>

                    <% if (job.deadline) { %>
                        <%= new Date(job.deadline).toLocaleDateString(
                            'en-SG',
                            {
                                day: '2-digit',
                                month: 'short',
                                year: 'numeric'
                            }
                        ) %>
                    <% } else { %>
                        No deadline
                    <% } %>
                </p>

                <div class="d-flex flex-wrap gap-2">
                    <% if (user.role === 'student') { %>
                        <a href="/job/<%= job.id %>/apply" class="btn btn-worklah">
                            Apply for this Job
                        </a>

                        <% if (isBookmarked) { %>
                            <form action="/bookmark/<%= job.id %>/delete" method="POST" class="m-0">

                                <input type="hidden" name="returnPage" value="jobInfo">

                                <button type="submit" class="btn btn-outline-danger">Remove Saved</button>
                            </form>
                        <% } else { %>
                            <form action="/bookmark/<%= job.id %>" method="POST" class="m-0">

                                <input type="hidden" name="returnPage" value="jobInfo">

                                <button type="submit" class="btn btn-outline-primary">Save Job</button>
                            </form>
                        <% } %>
                    <% } %>

                    <a href="/joblist" class="btn btn-secondary">Back to Jobs</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
