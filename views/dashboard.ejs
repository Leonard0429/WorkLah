<!DOCTYPE html>
<html>
<head>
    <title>Dashboard - WorkLah</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">WorkLah</a>
            <div>
                <a class="btn btn-outline-light me-2" href="/joblist">Jobs</a>
                <% if (user.role === 'admin') { %>
                    <a class="btn btn-outline-light me-2" href="/admin">Admin</a>
                <% } %>
                <a class="btn btn-danger" href="/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <h1>Welcome, <%= user.username %>!</h1>
        <p>You are logged in as: <strong><%= user.role %></strong></p>
        <p>Email: <%= user.email %></p>

        <a href="/joblist" class="btn btn-primary mt-3">Browse Job Listings</a>
    </div>
</body>
</html>