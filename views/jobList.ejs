<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Worklah App</title>
</head>

<body>
    <%- include ('partials/navbar.ejs') %>
        <div class="container mt-3">
            <h2>Worklah</h2>
            <form method="GET" action="/joblist">
                <input type="text" name="search" placeholder="Search job title" value="<%= search || '' %>">

                <select name="company">
                    <option value="">All Companies</option>
                    <% companies.forEach(c=> { %>
                        <option value="<%= c %>" <%=company===c ? 'selected' : '' %>><%= c %>
                        </option>
                        <% }) %>
                </select>

                <select name="sort">
                    <option value="">Sort by...</option>
                    <option value="date" <%=sort==='date' ? 'selected' : '' %>>Date</option>
                </select>

                <button type="submit">Filter</button>
            </form>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Job ID</th>
                        <th>Company</th>
                        <th>Job Title</th>
                        <th>Date</th>
                        <th>Info</th>
                        <th>Apply</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Display the applicant information by looping through the applicant array-->
                    <% for (let i=0; i < job.length; i++) { %>
                        <tr>
                            <td>
                                <%= job[i].id %>
                            </td>
                            <td>
                                <%= job[i].company %>
                            </td>
                            <td>
                                <%= job[i].job_title %>
                            </td>
                            <td>
                                <%= job[i].date %>
                            </td>
                            <td><a href="/job/<%= job[i].id %>">Info</a></td>
                            <td><a href="/job/<%= job[i].id %>/apply">Apply</a></td>

                        </tr>
                        <% } %>
                </tbody>
            </table>
        </div>
</body>

</html>