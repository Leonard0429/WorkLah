<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <%- include('partials/styles.ejs') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js">
    </script>
    <title>My Profile</title>
</head>
<body>
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-5">
        <div class="card worklah-card form-card">
            <div class="card-header worklah-card-header">
                <h3 class="mb-0">My Profile</h3>
            </div>

            <div class="card-body">
                <% if (messages && messages.length > 0) { %>
                    <div class="alert alert-success">
                        <% messages.forEach(function(message) { %>
                            <p class="mb-0"><%= message %></p>
                        <% }); %>
                    </div>
                <% } %>

                <% if (errors && errors.length > 0) { %>
                    <div class="alert alert-danger">
                        <% errors.forEach(function(error) { %>
                            <p class="mb-0"><%= error %></p>
                        <% }); %>
                    </div>
                <% } %>

                <div class="text-center mb-4">
                    <% if (profilePictureAvailable) { %>
                        <img src="/profile-picture/<%= profile.id %>" alt="<%= profile.username %> profile picture"
                            class="profile-picture">
                    <% } else { %>
                        <div class="profile-picture-placeholder mx-auto">
                            <%= profile.username
                                .charAt(0)
                                .toUpperCase() %>
                        </div>
                    <% } %>

                    <h4 class="page-title mt-3">
                        <%= profile.username %>
                    </h4>

                    <form action="/profile/picture" method="POST" enctype="multipart/form-data" class="mt-3">

                        <label for="profilePicture" class="form-label">Profile Picture</label>

                        <input type="file" id="profilePicture" name="profilePicture" class="form-control"
                            accept=".jpg,.jpeg,.png,image/jpeg,image/png" required>

                        <div class="form-text">
                            JPG or PNG, maximum 2 MB.
                        </div>

                        <button type="submit" class="btn btn-worklah mt-2">
                            <%= profilePictureAvailable
                                ? 'Replace Picture'
                                : 'Upload Picture' %>
                        </button>
                    </form>
                </div>

                <hr>

                <form action="/profile" method="POST" enctype="multipart/form-data">

                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" class="form-control" value="<%= profile.username %>" readonly>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" value="<%= profile.email %>" readonly>
                    </div>

                    <div class="mb-3">
                        <label for="address" class="form-label">Address</label>
                        <input type="text" id="address" name="address" class="form-control"
                            value="<%= profile.address || '' %>" required>
                    </div>

                    <div class="mb-3">
                        <label for="contact" class="form-label">Contact Number</label>
                        <input type="text" id="contact" name="contact" class="form-control"
                            value="<%= profile.contact || '' %>" required>
                    </div>

                    <div class="mb-3">
                        <label for="resume" class="form-label">Resume (PDF, maximum 5 MB)</label>
                        <input type="file" id="resume" name="resume" class="form-control" accept=".pdf,application/pdf">

                        <% if (resumeAvailable) { %>
                            <div class="mt-2">
                                <span class="text-success">A profile resume is saved.</span>
                                <a href="/profile/resume" class="btn btn-outline-primary btn-sm ms-2">View Resume</a>
                            </div>
                        <% } else { %>
                            <div class="form-text text-danger">
                                Upload a resume before applying for a job.
                            </div>
                        <% } %>
                    </div>

                    <button type="submit" class="btn btn-worklah">Save Profile</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
