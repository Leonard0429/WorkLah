<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Edit Job</title>
</head>
<body>
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-3">
        <h2>Edit Job</h2>

        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <% errors.forEach(function(error) { %>
                    <p class="mb-0"><%= error %></p>
                <% }); %>
            </div>
        <% } %>

        <form action="/job/<%= job.id %>/edit" method="POST">
            <div class="mb-3">
                <label for="company" class="form-label">Company</label>
                <input type="text" id="company" name="company" class="form-control" value="<%= job.company %>" required>
            </div>

            <div class="mb-3">
                <label for="title" class="form-label">Job Title</label>
                <input type="text" id="title" name="title" class="form-control" value="<%= job.title %>" required>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea id="description" name="description" class="form-control" required><%= job.description %></textarea>
            </div>

            <div class="mb-3">
                <label for="category" class="form-label">Category</label>
                <input type="text" id="category" name="category" class="form-control" value="<%= job.category %>" required>
            </div>

            <div class="mb-3">
                <label for="pay" class="form-label">Pay</label>
                <input type="number" id="pay" name="pay" class="form-control" value="<%= job.pay %>" min="0" step="0.01" required>
            </div>

            <div class="mb-3">
                <label for="location" class="form-label">Location</label>
                <input type="text" id="location" name="location" class="form-control" value="<%= job.location || '' %>">
            </div>

            <div class="mb-3">
                <label for="deadline" class="form-label">Application Deadline</label>
                <input type="date" id="deadline" name="deadline" class="form-control" value="<%= job.deadline %>" required>
            </div>

            <button type="submit" class="btn btn-primary">
                Save Changes
            </button>
            <a href="/joblist" class="btn btn-secondary">
                Cancel
            </a>
        </form>
    </div>
</body>
</html>
